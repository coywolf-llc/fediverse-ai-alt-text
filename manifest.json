{
  "manifest_version": 3,
  "name": "AI Alt Text for Mastodon",
  "version": "1.0.4",
  "description": "Generate image alt text in Mastodon using your own Claude API key, following accessibility best practices. Privacy-first.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "scripting"],
  "host_permissions": ["https://api.anthropic.com/*"],
  "optional_host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "AI Alt Text for Mastodon — Settings",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "src/options.html"
}
